# ── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here

# Model to use for the orchestrator and draft generation (default: gpt-4o)
LLM_MODEL=gpt-4o

# Optional: use a lighter/faster model just for search ranking & query building
# RANK_LLM_MODEL=gpt-4o-mini

# Optional: use a different model just for draft generation
# DRAFT_LLM_MODEL=gpt-4o-mini

# ── Gmail OAuth ───────────────────────────────────────────────────────────────
# Path to your OAuth 2.0 credentials file downloaded from Google Cloud Console
GMAIL_CREDENTIALS_PATH=credentials.json

# ── Sending Policy ────────────────────────────────────────────────────────────
# true  = save replies as Gmail drafts only (safe default)
# false = allow sending emails to addresses in ALLOWED_SEND_ADDRESSES
DRY_RUN=true

# Comma-separated list of addresses the agent is permitted to send to
# Only relevant when DRY_RUN=false
ALLOWED_SEND_ADDRESSES=your_email@gmail.com

# ── LangSmith Tracing (optional) ─────────────────────────────────────────────
# Get your API key at https://smith.langchain.com → Settings → API Keys
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT=walkme-email-agent
